{
  "name": "morsetime",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator",
      "asUser": ["SUBMIT_COMMENT"]
    }
  },
  "menu": {
    "items": [
      {
        "label": "Post Today's Frequency",
        "description": "Create a new daily Morse code challenge post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-frequency"
      },
      {
        "label": "Pin / refresh leaderboard",
        "description": "Create or re-sticky the auto-updating leaderboard comment on this post",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/pin-leaderboard"
      },
      {
        "label": "View Subreddit Stats",
        "description": "View engagement stats for MorseTime",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/view-stats"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "daily-frequency-post": {
        "endpoint": "/internal/scheduler/daily-frequency-post",
        "cron": "0 0 * * *",
        "data": {
          "subreddit": "morsetime_dev"
        }
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "morsetime_dev"
  }
}
